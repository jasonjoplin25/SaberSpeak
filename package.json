{
  "name": "saberspeak",
  "version": "1.0.0",
  "description": "On-device voice dictation for Windows — powered by Moonshine STT",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsup --watch\" \"wait-on dist/main/index.js && electron .\"",
    "build": "tsup && node scripts/copy-assets.mjs",
    "bundle-python": "node scripts/bundle-python.mjs",
    "dist": "tsup && node scripts/copy-assets.mjs && electron-builder --win",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-log": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  }
}
